<!DOCTYPE html>
<html lang="id">
<head>
    <meta charset="UTF-8">
    <title>Futsal Arena Booking</title>
    <link rel="stylesheet" href="/css/style.css">
</head>
<body>

<header class="navbar">
    <div class="logo">
        ⚽ FUTSAL <span>ARENA</span>
    </div>

    <nav>
        <a href="/">Beranda</a>
        <a href="/login">Login</a>
        <a href="/register" class="register-btn">Register</a>
    </nav>
</header>

<section class="hero-section">
    <div class="overlay"></div>

    <div class="hero-content">
        <h1>
            Booking Lapangan Futsal
            <span>Jadi Lebih Mudah</span>
        </h1>

        <p>
            Pesan lapangan favoritmu secara online, cepat,
            praktis, dan tanpa antre.
        </p>

        <div class="feature-row">
            <div class="feature-box">
                📅
                <h3>Jadwal Fleksibel</h3>
                <p>Pilih jadwal kapan saja.</p>
            </div>

            <div class="feature-box">
                🛡
                <h3>Aman</h3>
                <p>Booking terpercaya.</p>
            </div>

            <div class="feature-box">
                ⚡
                <h3>Instan</h3>
                <p>Konfirmasi cepat.</p>
            </div>
        </div>

        <div class="hero-buttons">
            <a href="/booking" class="book-btn">Book Now</a>
            <a href="/login" class="secondary-btn">Login</a>
        </div>
    </div>
</section>

<section class="advantages">
    <h2>Keunggulan Futsal Arena</h2>

    <div class="advantages-grid">
        <div class="adv-card">
            <h3>🏟 Banyak Lapangan</h3>
            <p>Tersedia beberapa pilihan lapangan.</p>
        </div>

        <div class="adv-card">
            <h3>💸 Harga Terjangkau</h3>
            <p>Harga kompetitif untuk semua kalangan.</p>
        </div>

        <div class="adv-card">
            <h3>🕒 Realtime</h3>
            <p>Cek slot kosong secara langsung.</p>
        </div>
    </div>
</section>

</body>
</html>