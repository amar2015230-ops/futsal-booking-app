<!DOCTYPE html>
<html>
<head>
    <title>Admin</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">

<div class="container mt-5">
    <h1>Admin Panel</h1>

    <form action="/admin/add" method="POST" class="mb-4">
        <input name="nama_lapangan" placeholder="Nama Lapangan" required>
        <input name="harga_per_jam" placeholder="Harga" required>
        <button class="btn btn-primary">Tambah</button>
    </form>

    <table class="table table-bordered">
    <tr>
        <th>ID</th>
        <th>Nama</th>
        <th>Harga</th>
        <th>Aksi</th>
    </tr>

    <% lapangan.forEach(item => { %>
    <tr>
        <td><%= item.id %></td>
        <td><%= item.nama_lapangan %></td>
        <td><%= item.harga_per_jam %></td>
        <td>
            <a href="/admin/delete/<%= item.id %>" class="btn btn-danger btn-sm">
                Delete
            </a>
        </td>
    </tr>
    <% }) %>
</table>
</div>

</body>
</html>